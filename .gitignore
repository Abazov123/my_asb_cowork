# Personal vault content (created at runtime, not shared)
vault/daily/*
!vault/daily/.gitkeep
vault/thoughts/**/*
!vault/thoughts/**/.gitkeep
vault/attachments/*
!vault/attachments/.gitkeep
vault/summaries/*
!vault/summaries/.gitkeep
vault/blog/*
vault/agent/*
!vault/agent/.gitkeep
vault/MOC/*
!vault/MOC/.gitkeep

